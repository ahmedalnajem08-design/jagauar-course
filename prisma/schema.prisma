generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Trainer {
  id        String   @id @default(cuid())
  name      String
  phone     String   @default("")
  password  String
  role      String   @default("trainer") // "admin" or "trainer"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainees       Trainee[]
  exerciseGroups ExerciseGroup[]
  courses        Course[]
}

model Trainee {
  id               String   @id @default(cuid())
  name             String
  phone            String   @default("")
  gender           String   @default("male") // "male" or "female"
  weight           Float
  height           Float
  age              Int
  subscriptionDate DateTime @default(now())
  trainerId        String
  trainer          Trainer  @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  courses          Course[]
}

model ExerciseGroup {
  id          String     @id @default(cuid())
  name        String
  description String?
  trainerId   String
  trainer     Trainer    @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  exercises   Exercise[]
}

model Exercise {
  id          String        @id @default(cuid())
  name        String
  description String?
  sets        Int           @default(3)
  reps        Int           @default(10)
  groupId     String
  group       ExerciseGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  courseDayExercises CourseDayExercise[]
}

model Course {
  id           String       @id @default(cuid())
  traineeId    String
  trainee      Trainee      @relation(fields: [traineeId], references: [id], onDelete: Cascade)
  trainerId    String
  trainer      Trainer      @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  numberOfDays Int
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  days         CourseDay[]
}

model CourseDay {
  id         String              @id @default(cuid())
  courseId   String
  course     Course              @relation(fields: [courseId], references: [id], onDelete: Cascade)
  dayNumber  Int
  exercises  CourseDayExercise[]

  @@unique([courseId, dayNumber])
}

model CourseDayExercise {
  id           String     @id @default(cuid())
  courseDayId  String
  courseDay    CourseDay  @relation(fields: [courseDayId], references: [id], onDelete: Cascade)
  exerciseId   String
  exercise     Exercise   @relation(fields: [exerciseId], references: [id])
  customSets   Int?
  customReps   Int?
  order        Int        @default(0)
}

model Setting {
  key   String @id
  value String
}
